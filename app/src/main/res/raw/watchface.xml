<?xml version="1.0" encoding="UTF-8"?>
<WatchFace width="450" height="450">
    <Metadata key="CLOCK_TYPE" value="DIGITAL"/>
    <Metadata key="PREVIEW_TIME" value="10:08:32"/>

    <!-- ============ EDITOR CONFIGURATION PAGES ============ -->
    <!-- Each configuration appears as a page in the watch face customize screen.
         aodComplications: when FALSE (default), complications are hidden in
         always-on/ambient; when TRUE they remain visible. -->
    <UserConfigurations>
        <BooleanConfiguration id="aodComplications"
            displayName="config_aod_complications"
            screenReaderText="config_aod_complications"
            defaultValue="FALSE"/>
        <!-- Time color picker. Each option is a single ARGB color referenced as
             [CONFIGURATION.timeColor]. Default white = unchanged look. -->
        <ColorConfiguration id="timeColor"
            displayName="config_time_color"
            screenReaderText="config_time_color"
            defaultValue="white">
            <ColorOption id="white"  displayName="color_white"  colors="#ffffffff"/>
            <ColorOption id="red"    displayName="color_red"    colors="#ffff5252"/>
            <ColorOption id="orange" displayName="color_orange" colors="#ffff9800"/>
            <ColorOption id="yellow" displayName="color_yellow" colors="#ffffeb3b"/>
            <ColorOption id="green"  displayName="color_green"  colors="#ff4caf50"/>
            <ColorOption id="cyan"   displayName="color_cyan"   colors="#ff00e5ff"/>
            <ColorOption id="blue"   displayName="color_blue"   colors="#ff2196f3"/>
            <ColorOption id="purple" displayName="color_purple" colors="#ff9c27b0"/>
            <ColorOption id="pink"   displayName="color_pink"   colors="#ffff4081"/>
        </ColorConfiguration>
        <!-- Complication color picker, referenced as [CONFIGURATION.complicationColor]. -->
        <ColorConfiguration id="complicationColor"
            displayName="config_complication_color"
            screenReaderText="config_complication_color"
            defaultValue="white">
            <ColorOption id="white"  displayName="color_white"  colors="#ffffffff"/>
            <ColorOption id="red"    displayName="color_red"    colors="#ffff5252"/>
            <ColorOption id="orange" displayName="color_orange" colors="#ffff9800"/>
            <ColorOption id="yellow" displayName="color_yellow" colors="#ffffeb3b"/>
            <ColorOption id="green"  displayName="color_green"  colors="#ff4caf50"/>
            <ColorOption id="cyan"   displayName="color_cyan"   colors="#ff00e5ff"/>
            <ColorOption id="blue"   displayName="color_blue"   colors="#ff2196f3"/>
            <ColorOption id="purple" displayName="color_purple" colors="#ff9c27b0"/>
            <ColorOption id="pink"   displayName="color_pink"   colors="#ffff4081"/>
        </ColorConfiguration>
    </UserConfigurations>

