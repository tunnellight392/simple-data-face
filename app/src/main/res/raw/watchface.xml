        <!-- ============ AOD COMPLICATION HIDE PANELS ============ -->
        <!-- These render AFTER the complications (so they cover them) but only in
             ambient mode, and only when the user has NOT enabled "Complications in
             always-on". Pure black on the black background = the complications
             vanish in always-on. When the toggle is TRUE, no panels are drawn. -->
        <BooleanConfiguration id="aodComplications">
            <BooleanOption id="FALSE">
                <PartDraw x="0" y="0" width="450" height="160" alpha="0">
                    <Variant mode="AMBIENT" target="alpha" value="255"/>
                    <Rectangle x="0" y="0" width="450" height="160">
                        <Fill color="#ff000000"/>
                    </Rectangle>
                </PartDraw>
                <PartDraw x="0" y="290" width="450" height="160" alpha="0">
                    <Variant mode="AMBIENT" target="alpha" value="255"/>
                    <Rectangle x="0" y="0" width="450" height="160">
                        <Fill color="#ff000000"/>
                    </Rectangle>
                </PartDraw>
            </BooleanOption>
            <BooleanOption id="TRUE">
            </BooleanOption>
        </BooleanConfiguration>

        <!-- ============ CENTER TIME ============ -->
        <!-- Time is right-aligned to a fixed right edge so the AM/PM marker can sit
             immediately to its right, vertically centered with the digits. -->
        <DigitalClock x="0" y="165" width="450" height="120">
            <!-- ONE hours:minutes element for both modes. Interactive it is right-
                 aligned (right edge at 343, leaving room for the seconds + AM/PM on
                 the right). In ambient those are gone, so the same element slides
                 right to sit centered. Animating a single element gives a smooth
                 transition instead of cross-fading two copies at different x. -->
            <TimeText format="hh:mm" hourFormat="12" align="END" x="0" y="0" width="343" height="120" alpha="255">
                <Variant mode="AMBIENT" target="x" value="30"/>
                <Font family="SYNC_TO_DEVICE" size="116" color="[CONFIGURATION.timeColor]"/>
            </TimeText>
            <!-- Seconds: fade out in place (no off-screen slide). -->
            <TimeText format="ss" align="START" x="355" y="11" width="95" height="46" alpha="255">
                <Variant mode="AMBIENT" target="alpha" value="0"/>
                <Font family="SYNC_TO_DEVICE" size="40" color="[CONFIGURATION.timeColor]"/>
            </TimeText>
        </DigitalClock>

        <!-- ============ AM / PM (right of the time) ============ -->
        <Group x="355" y="232" width="95" height="46" name="am_pm">
            <Condition>
                <Expressions>
                    <Expression name="isPm"><![CDATA[[AMPM_STATE] == 1]]></Expression>
                </Expressions>
                <Compare expression="isPm">
                    <PartText x="0" y="0" width="95" height="46">
                        <Variant mode="AMBIENT" target="alpha" value="0"/>
                        <Text align="START">
                            <Font family="SYNC_TO_DEVICE" size="30" color="[CONFIGURATION.timeColor]">
                                <Template><![CDATA[PM]]></Template>
                            </Font>
                        </Text>
                    </PartText>
                </Compare>
                <Default>
                    <PartText x="0" y="0" width="95" height="46">
                        <Variant mode="AMBIENT" target="alpha" value="0"/>
                        <Text align="START">
                            <Font family="SYNC_TO_DEVICE" size="30" color="[CONFIGURATION.timeColor]">
                                <Template><![CDATA[AM]]></Template>
                            </Font>
                        </Text>
                    </PartText>
                </Default>
            </Condition>
        </Group>

    </Scene>
</WatchFace>
